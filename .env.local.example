NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only Supabase service role key. Required for /api/certificates/issue
# (mints signed certificates with bypassed RLS). Never commit this; set in
# Vercel project env as encrypted.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Ed25519 private key (PKCS8 DER, base64). Used by /api/certificates/issue
# to sign payloads. The matching public key is committed in
# src/lib/cert-keys.ts and used everywhere for verification. Generate a new
# one with:
#   node -e "const { generateKeyPairSync } = require('node:crypto'); const
#   { publicKey, privateKey } = generateKeyPairSync('ed25519');
#   console.log('PUBLIC=', publicKey.export({type:'spki',format:'der'})
#     .toString('base64'));
#   console.log('PRIVATE=', privateKey.export({type:'pkcs8',format:'der'})
#     .toString('base64'));"
UDEMI_CERT_PRIVATE_KEY=
